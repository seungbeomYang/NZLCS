# Sanity ----------------------------------------------------------------
# Public — exposed to the browser via NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_SANITY_PROJECT_ID=53ioacj3
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-01-01

# Server-only — used by the draft-mode route handler and sanityFetch wrapper.
# Create at https://www.sanity.io/manage/personal/project/53ioacj3/api → Tokens.
# Permissions: Viewer is enough for read; needs to be able to read drafts.
SANITY_API_READ_TOKEN=

# Server-only — random string of your choosing. Used by /api/draft to verify
# preview links before flipping the draft cookie. Keep it secret.
SANITY_PREVIEW_SECRET=

# Server-only — paste the same value into your Sanity webhook secret config.
# Used by /api/revalidate to verify webhook signatures (wire after deploy).
SANITY_REVALIDATE_SECRET=

# Server-only — used ONLY by scripts/import-content.ts. Needs Editor permissions.
# You can revoke this token in the Sanity Manage console after the import runs.
SANITY_API_WRITE_TOKEN=

# Contact form (Resend) ------------------------------------------------
# Server-only. Create at https://resend.com/api-keys.
RESEND_API_KEY=

# Where quote inquiries are delivered. Defaults to info@nzlcs.co.nz.
CONTACT_TO_EMAIL=info@nzlcs.co.nz

# The "from" address. Until your domain is verified in Resend, use the
# sandbox sender: "NZLCS Website <onboarding@resend.dev>". After verifying
# nzlcs.co.nz, switch to e.g. "NZLCS Website <noreply@nzlcs.co.nz>".
CONTACT_FROM_EMAIL=NZLCS Website <onboarding@resend.dev>
